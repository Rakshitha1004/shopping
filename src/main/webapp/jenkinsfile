pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/Rakshitha1004/shopping.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Deploy') {
            steps {
                sh 'cp target/devops-webapp.war /opt/tomcat/webapps/'
            }
        }
    }
}
